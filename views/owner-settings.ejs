          <div class="settings-expander-summary-main">
            <h2 class="section-icon-title">
              <span class="section-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.8" /><path d="M3 10h18" stroke="currentColor" stroke-width="1.8" /></svg>
              </span>
              <%= t('ownerSettings.creditPacks.title', { defaultValue: 'One-Time Credit Packs' }) %>
            </h2>
            <p class="muted"><%= t('ownerSettings.creditPacks.subtitle', { defaultValue: 'Update IDs, display names, credits, internal cost, and price (cents). Cost is owner-only and used for profit analytics.' }) %></p>
          </div>
          <span class="schedule-expander-plus" aria-hidden="true">+</span>
        </summary>
        <div class="settings-expander-body">
      <% const mostPopularPackSet = new Set((mostPopularCreditPackIds || []).map((id) => String(id))); %>
      <% const purchaseCounts = creditPackPurchaseCounts || {}; %>
      <div class="level-rows" id="creditPackRows">
        <% settings.pricing.credit_packs.forEach((pack) => { %>
          <% if (mostPopularPackSet.has(String(pack.id))) { %>
            <% const count = Number(purchaseCounts[String(pack.id)] || 0); %>
            <div class="pricing-row-popular">
              <span class="tier-saving-badge">Most popular · <%= count.toLocaleString() %> purchase<%= count === 1 ? '' : 's' %></span>
            </div>
          <% } %>
          <div class="level-row pricing-row">
            <label>
              ID
              <input type="text" name="pack_id" value="<%= pack.id %>" maxlength="40" required />
            </label>
            <label>
              Name
              <input type="text" name="pack_name" value="<%= pack.name %>" maxlength="64" required />
            </label>
            <label>
              Credits
              <input type="number" name="pack_credits" value="<%= pack.credits %>" min="1" required />
            </label>
            <label>
              Cost (cents)
              <input type="number" name="pack_cost_cents" value="<%= Number(pack.costUnitCents || 0) %>" min="0" required />
            </label>
            <label>
              Price (cents)
              <input type="number" name="pack_price_cents" value="<%= pack.unitAmountCents %>" min="1" required />
            </label>
            <button type="button" class="btn btn-ghost remove-pricing-row">Remove</button>
          </div>
        <% }) %>
      </div>
      <div class="form-actions">
        <button type="button" id="addCreditPackRowBtn" class="btn btn-ghost">Add Credit Pack</button>
      </div>
        </div>
      </details>
