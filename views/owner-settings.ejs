<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<main class="container page-section">
  <div class="page-head">
    <div>
      <h1 class="section-icon-title">
        <span class="section-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 3l2.2 2.2 3.1-.6.6 3.1L20 10l-2.1 2 2.1 2-2.1 2 .5 3.1-3.1.6L12 22l-2.2-2.2-3.1.6-.6-3.1L4 14l2.1-2L4 10l2.1-2-.5-3.1 3.1-.6L12 3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8" />
          </svg>
        </span>
        <%= t('ownerSettings.title', { defaultValue: 'Owner Settings' }) %>
      </h1>
      <p class="muted"><%= t('ownerSettings.subtitle', { defaultValue: 'Global bot channel configuration and website pricing tiers.' }) %></p>
    </div>
    <a href="/dashboard" class="btn btn-ghost btn-with-icon"><span class="btn-icon" aria-hidden="true">←</span><%= t('common.back', { defaultValue: 'Back' }) %></a>
  </div>

  <% if (saved) { %>
    <div class="alert success"><%= t('ownerSettings.saved', { defaultValue: 'Owner settings saved successfully.' }) %></div>
  <% } %>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="4" y="4" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.8" />
                <path d="M8 9h8M8 13h8M8 17h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            </span>
            <%= t('ownerSettings.metadata', { defaultValue: 'Settings Metadata' }) %>
          </h2>
          <p class="muted"><%= t('ownerSettings.metadataSubtitle', { defaultValue: 'Audit information about when owner settings were last updated and by whom.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <p class="muted">
      Last updated:
      <% if (settingsMeta && settingsMeta.updatedAt) { %>
        <strong><%= new Date(settingsMeta.updatedAt).toLocaleString() %></strong>
      <% } else { %>
        <strong>Never</strong>
      <% } %>
      · Updated by:
      <% if (settingsMeta && (settingsMeta.updatedByDisplay || settingsMeta.updatedByUserId)) { %>
        <% if (settingsMeta.updatedByUserId) { %>
          <strong>
            <a href="https://discord.com/users/<%= settingsMeta.updatedByUserId %>" target="_blank" rel="noopener noreferrer">
              <%= settingsMeta.updatedByDisplay || settingsMeta.updatedByUserId %>
            </a>
          </strong>
        <% } else { %>
          <strong><%= settingsMeta.updatedByDisplay || settingsMeta.updatedByUserId %></strong>
        <% } %>
      <% } else { %>
        <strong>Unknown</strong>
      <% } %>
        </p>
        <% if (settingsMeta && settingsMeta.createdAt) { %>
          <p class="muted">Created: <strong><%= new Date(settingsMeta.createdAt).toLocaleString() %></strong></p>
        <% } %>
      </div>
    </details>
  </section>

  <form method="post" action="/owner/settings">
    <section class="panel">
      <details class="settings-expander">
        <summary class="settings-expander-summary">
          <div class="settings-expander-summary-main">
            <h2 class="section-icon-title">
              <span class="section-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z" stroke="currentColor" stroke-width="1.8" />
                  <path d="M3 12h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              </span>
              <%= t('ownerSettings.websiteUrl', { defaultValue: 'Website URL' }) %>
            </h2>
            <p class="muted"><%= t('ownerSettings.websiteUrlSubtitle', { defaultValue: 'Owner-only: used by the bot `/website` command.' }) %></p>
          </div>
          <span class="schedule-expander-plus" aria-hidden="true">+</span>
        </summary>
        <div class="settings-expander-body">
          <div class="level-rows">
        <div class="level-row">
          <label>
            Website Base URL
            <input type="url" name="website_base_url" value="<%= settings.website.base_url %>" placeholder="https://yourdomain.com" required />
          </label>
        </div>
          </div>
        </div>
      </details>
    </section>

    <section class="panel">
