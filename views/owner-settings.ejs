<script>
  const creditPackRows = document.getElementById('creditPackRows');
  const subscriptionPlanRows = document.getElementById('subscriptionPlanRows');
  const translationPlanRows = document.getElementById('translationPlanRows');
  const addCreditPackRowBtn = document.getElementById('addCreditPackRowBtn');
  const addSubscriptionPlanRowBtn = document.getElementById('addSubscriptionPlanRowBtn');
  const addTranslationPlanRowBtn = document.getElementById('addTranslationPlanRowBtn');

  function wireRemovePricingButtons() {
    document.querySelectorAll('.remove-pricing-row').forEach((button) => {
      button.onclick = () => {
        const rowContainer = button.closest('.level-rows');
        if (!rowContainer) {
          return;
        }

        const rows = rowContainer.querySelectorAll('.pricing-row');
        if (rows.length <= 1) {
          return;
        }

        button.closest('.pricing-row')?.remove();
      };
    });
  }

  function createPricingRow(fields) {
    const row = document.createElement('div');
    row.className = 'level-row pricing-row';

    row.innerHTML = fields.map((field) => {
      const minAttr = field.min ? ` min="${field.min}"` : '';
      const maxLengthAttr = field.maxLength ? ` maxlength="${field.maxLength}"` : '';
      const placeholderAttr = field.placeholder ? ` placeholder="${field.placeholder}"` : '';
      const valueAttr = field.value !== undefined ? ` value="${field.value}"` : '';

      return `
        <label>
          ${field.label}
          <input type="${field.type}" name="${field.name}"${valueAttr}${minAttr}${maxLengthAttr}${placeholderAttr} required />
        </label>
      `;
    }).join('');

    const removeButton = document.createElement('button');
    removeButton.type = 'button';
    removeButton.className = 'btn btn-ghost remove-pricing-row';
    removeButton.textContent = 'Remove';
    row.appendChild(removeButton);

    return row;
  }

  addCreditPackRowBtn?.addEventListener('click', () => {
    if (!creditPackRows) {
      return;
    }

    const row = createPricingRow([
      { label: 'ID', type: 'text', name: 'pack_id', maxLength: 40, placeholder: 'e.g. ultra' },
      { label: 'Name', type: 'text', name: 'pack_name', maxLength: 64, placeholder: 'e.g. Ultra' },
      { label: 'Credits', type: 'number', name: 'pack_credits', min: 1, value: 1 },
      { label: 'Cost (cents)', type: 'number', name: 'pack_cost_cents', min: 0, value: 0 },
      { label: 'Price (cents)', type: 'number', name: 'pack_price_cents', min: 1, value: 100 },
    ]);

    creditPackRows.appendChild(row);
    wireRemovePricingButtons();
  });

  addSubscriptionPlanRowBtn?.addEventListener('click', () => {
    if (!subscriptionPlanRows) {
      return;
    }

    const row = createPricingRow([
      { label: 'ID', type: 'text', name: 'plan_id', maxLength: 40, placeholder: 'e.g. ultra_monthly' },
      { label: 'Name', type: 'text', name: 'plan_name', maxLength: 64, placeholder: 'e.g. Ultra Monthly' },
      { label: 'Credits / month', type: 'number', name: 'plan_credits_per_month', min: 1, value: 1 },
      { label: 'Cost (cents)', type: 'number', name: 'plan_cost_cents', min: 0, value: 0 },
      { label: 'Price (cents)', type: 'number', name: 'plan_price_cents', min: 1, value: 100 },
    ]);

    subscriptionPlanRows.appendChild(row);
    wireRemovePricingButtons();
  });

  addTranslationPlanRowBtn?.addEventListener('click', () => {
    if (!translationPlanRows) {
      return;
    }

    const row = createPricingRow([
      { label: 'ID', type: 'text', name: 'translation_plan_id', maxLength: 40, placeholder: 'e.g. translation_enterprise_monthly' },
      { label: 'Name', type: 'text', name: 'translation_plan_name', maxLength: 64, placeholder: 'e.g. Enterprise Translation' },
      { label: 'Characters / month', type: 'number', name: 'translation_plan_characters_per_month', min: 1, value: 10000 },
      { label: 'Cost (cents)', type: 'number', name: 'translation_plan_cost_cents', min: 0, value: 0 },
      { label: 'Price (cents)', type: 'number', name: 'translation_plan_price_cents', min: 1, value: 100 },
    ]);

    translationPlanRows.appendChild(row);
    wireRemovePricingButtons();
  });

  wireRemovePricingButtons();
</script>

