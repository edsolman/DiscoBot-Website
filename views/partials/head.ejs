<!doctype html>
<html lang="<%= currentLanguage || 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0b1020" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="DiscoBot" />
  <title><%= title %> · <%= t('meta.siteName') %></title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/assets/DiscoBot.png" />
  <link rel="shortcut icon" href="/assets/DiscoBot.png" />
  <link rel="apple-touch-icon" href="/assets/DiscoBot.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <script>
    window.discoI18n = <%- JSON.stringify({
      pwaUpdateAvailable: t('pwa.updateAvailable'),
      pwaUpdateText: t('pwa.updateText'),
      pwaRefreshNow: t('pwa.refreshNow'),
      pwaIosInstallHint: t('pwa.iosInstallHint'),
      pwaUnavailableHint: t('pwa.unavailableHint')
    }) %>;
  </script>
</head>
