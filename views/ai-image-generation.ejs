<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<main class="container page-section" data-generation-status="<%= generationStatus %>">
  <div class="page-head page-head-branded">
    <div>
      <h1 class="section-icon-title">
        <span class="section-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.8" /><circle cx="9" cy="10" r="2" stroke="currentColor" stroke-width="1.8" /><path d="M6 18l4.5-4.5 3 3L16.5 14 20 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </span>
        <%= t('credits.generate.title', { defaultValue: 'Generate AI Image on Website' }) %>
      </h1>
      <p class="muted"><%= t('credits.generate.subtitle', { defaultValue: 'Use your personal AI credits directly on the website without needing a Discord guild channel.' }) %></p>
      <div class="form-actions" style="margin-top: 10px;">
        <a href="/credits" class="btn btn-ghost"><%= t('nav.aiCredits', { defaultValue: 'AI Credits' }) %></a>
        <a href="/my-account" class="btn btn-ghost btn-with-icon"><span class="btn-icon" aria-hidden="true">←</span><%= t('common.back', { defaultValue: 'Back' }) %></a>
      </div>
    </div>
  </div>

  <% if (generationStatus === 'success') { %>
    <div class="alert success"><%= t('credits.generate.success', { defaultValue: 'AI image generated successfully. 1 credit was used.' }) %></div>
  <% } %>
  <% if (generationStatus === 'no_credits') { %>
    <div class="alert warning"><%= t('credits.generate.noCredits', { defaultValue: 'You do not have enough AI credits to generate an image.' }) %></div>
  <% } %>
  <% if (generationStatus === 'invalid_prompt') { %>
    <div class="alert warning"><%= t('credits.generate.invalidPrompt', { defaultValue: 'Please enter a valid prompt before generating.' }) %></div>
  <% } %>
  <% if (generationStatus === 'invalid_image') { %>
    <div class="alert warning"><%= t('credits.generate.invalidImage', { defaultValue: 'Please upload a valid source image for edit mode.' }) %></div>
  <% } %>
  <% if (generationStatus === 'unavailable') { %>
    <div class="alert warning"><%= t('credits.generate.unavailable', { defaultValue: 'Web image generation is not available right now. Please try again later.' }) %></div>
  <% } %>
  <% if (generationStatus === 'failed') { %>
    <div class="alert warning"><%= t('credits.generate.failed', { defaultValue: 'Image generation failed. Your credit was refunded.' }) %></div>
  <% } %>

  <section class="panel">
    <details class="settings-expander" open>
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
            </span>
            <%= t('credits.yourBalance', { defaultValue: 'Your Balance' }) %>
          </h2>
          <p class="muted"><%= t('credits.balanceSubtitle', { defaultValue: 'Current available credits with purchased and used totals.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <p><strong><%= t('credits.availableCredits', { defaultValue: 'Available credits:' }) %></strong> <%= summary.balance %></p>
        <p class="muted"><%= t('credits.purchasedTotal', { defaultValue: 'Purchased total:' }) %> <%= summary.purchasedTotal %> · <%= t('credits.usedTotal', { defaultValue: 'Used total:' }) %> <%= summary.usedTotal %></p>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander" open>
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.8" /><circle cx="9" cy="10" r="2" stroke="currentColor" stroke-width="1.8" /><path d="M6 18l4.5-4.5 3 3L16.5 14 20 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </span>
            <%= t('credits.generate.createTitle', { defaultValue: 'Create AI Image' }) %>
          </h2>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <div data-generation-root>
          <div class="form-actions" style="margin-bottom: 10px;">
            <button type="button" class="btn btn-primary" data-generation-toggle="text" aria-pressed="true">
              <%= t('credits.generate.toggleGenerate', { defaultValue: 'Generate Image' }) %>
            </button>
            <button type="button" class="btn btn-ghost" data-generation-toggle="edit" aria-pressed="false">
              <%= t('credits.generate.toggleEdit', { defaultValue: 'Edit Image' }) %>
            </button>
          </div>

          <div data-generation-panel="text">
            <form method="post" action="/ai-image-generation/generate-image" class="import-form">
              <input type="hidden" name="generation_mode" value="text" />
              <label>
                <%= t('credits.generate.promptLabel', { defaultValue: 'Prompt' }) %>
                <textarea name="prompt" rows="4" maxlength="1500" placeholder="<%= t('credits.generate.promptPlaceholder', { defaultValue: 'Example: A retro-futuristic city skyline at sunset, neon lights, cinematic lighting' }) %>" required></textarea>
              </label>
              <div class="form-actions">
                <button
                  type="submit"
                  class="btn btn-primary"
                  data-default-label="<%= t('credits.generate.button', { defaultValue: 'Generate Image (1 credit)' }) %>"
                  data-loading-label="<%= t('credits.generate.buttonLoading', { defaultValue: 'Generating...' }) %>"
                ><%= t('credits.generate.button', { defaultValue: 'Generate Image (1 credit)' }) %></button>
              </div>
            </form>
          </div>

          <div data-generation-panel="edit" hidden>
            <form method="post" action="/ai-image-generation/generate-image" enctype="multipart/form-data" class="import-form">
              <input type="hidden" name="generation_mode" value="edit" />
              <label>
                <%= t('credits.generate.sourceImageLabel', { defaultValue: 'Source Image' }) %>
                <input type="file" name="source_image" accept="image/*" required />
              </label>
              <label>
                <%= t('credits.generate.editPromptLabel', { defaultValue: 'Edit Prompt' }) %>
                <textarea name="prompt" rows="3" maxlength="1500" placeholder="<%= t('credits.generate.editPromptPlaceholder', { defaultValue: 'Example: Turn this into a watercolor painting with warm sunset tones' }) %>" required></textarea>
              </label>
              <div class="form-actions">
                <button
                  type="submit"
                  class="btn btn-primary"
                  data-default-label="<%= t('credits.generate.editButton', { defaultValue: 'Edit Image (1 credit)' }) %>"
                  data-loading-label="<%= t('credits.generate.buttonLoading', { defaultValue: 'Generating...' }) %>"
                ><%= t('credits.generate.editButton', { defaultValue: 'Edit Image (1 credit)' }) %></button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander" data-history-expander>
      <summary class="settings-expander-summary" tabindex="-1" data-history-summary>
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M4 12h16M12 4v16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
            </span>
            <%= t('credits.generate.historyTitle', { defaultValue: 'Image History' }) %>
          </h2>
          <p class="muted"><%= t('credits.generate.historySubtitle', { defaultValue: 'Your recent AI image generations from the website and Discord bot.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <div class="generation-loading-card" data-history-loading role="status" aria-live="polite" hidden style="margin-bottom: 12px;">
          <span class="generation-loading-spinner" aria-hidden="true"></span>
          <div class="generation-loading-text">
            <span><%= t('credits.generate.loadingMessage', { defaultValue: 'Your image is being generated...' }) %></span>
            <span class="generation-loading-slow" data-history-loading-slow hidden><%= t('credits.generate.loadingSlowMessage', { defaultValue: 'Still working... this can take a little longer for complex requests.' }) %></span>
          </div>
        </div>

        <div class="purchase-list" data-history-list style="margin-top: 12px;<%= recentWebGenerations && recentWebGenerations.length ? '' : ' display:none;' %>">
          <% if (recentWebGenerations && recentWebGenerations.length) { %>
            <% recentWebGenerations.forEach((row) => { %>
              <% const isDiscoBotSource = row.source === 'discord_bot'; %>
              <% const sourceLabel = isDiscoBotSource ? t('credits.generate.sourceDiscordBot', { defaultValue: 'DiscoBot' }) : t('credits.generate.sourceWebsite', { defaultValue: 'Website' }); %>
              <div class="purchase-item ai-history-item" style="align-items: flex-start; gap: 12px; justify-content: flex-start;">
                <button
                  type="button"
                  class="history-image-trigger ai-history-thumb"
                  data-history-image-trigger
                  data-image-src="/credits/generated/<%= row.id %>"
                  data-image-alt="<%= t('credits.generate.generatedImageAlt', { defaultValue: 'Generated AI image' }) %>"
                >
                  <img src="/credits/generated/<%= row.id %>" alt="<%= t('credits.generate.generatedImageAlt', { defaultValue: 'Generated AI image' }) %>" style="width: 128px; height: 128px; border-radius: 10px; object-fit: cover; border: 1px solid rgba(255,255,255,0.18);" />
                </button>
                <div class="ai-history-body" style="min-width: 0;">
                  <div class="muted" style="margin-bottom: 6px;"><%= row.createdAt ? new Date(row.createdAt).toLocaleString() : '' %></div>
                  <div><strong><%= row.prompt %></strong></div>
                  <div class="muted"><%= row.mode === 'edit' ? t('credits.generate.modeEdit', { defaultValue: 'Image edit' }) : t('credits.generate.modeText', { defaultValue: 'Text-to-image' }) %> · <%= row.model %> · <span class="history-source-badge"><span class="history-source-badge-icon" aria-hidden="true"><% if (isDiscoBotSource) { %><img src="/assets/DiscoBot.png" alt="" /><% } else { %><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.8" /><path d="M4 12h16M12 4a13 13 0 0 1 0 16M12 4a13 13 0 0 0 0 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg><% } %></span><%= sourceLabel %></span></div>
                  <div class="form-actions" style="margin-top: 8px;">
                    <a href="/credits/generated/<%= row.id %>?download=1" class="btn btn-ghost" download><%= t('credits.generate.download', { defaultValue: 'Download' }) %></a>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
        <p class="muted" data-history-empty <%= recentWebGenerations && recentWebGenerations.length ? 'hidden' : '' %>><%= t('credits.generate.historyEmpty', { defaultValue: 'No images generated yet.' }) %></p>
      </div>
    </details>
  </section>
</main>

<div class="history-image-viewer" data-image-viewer hidden>
  <div class="history-image-viewer-backdrop" data-image-viewer-backdrop></div>
  <div class="history-image-viewer-dialog" role="dialog" aria-modal="true" aria-label="Image preview">
    <button type="button" class="history-image-viewer-close" data-image-viewer-close aria-label="Close preview">x</button>
    <img data-image-viewer-image src="" alt="" />
  </div>
</div>

<script>
(() => {
  const root = document.querySelector('[data-generation-root]');
  if (!root) {
    return;
  }

  const STORAGE_KEY = 'discobotCreditsGenerationMode';
  const pageRoot = document.querySelector('main[data-generation-status]');
  const generationStatus = pageRoot ? String(pageRoot.getAttribute('data-generation-status') || '').trim().toLowerCase() : '';

  const toggleButtons = Array.from(root.querySelectorAll('[data-generation-toggle]'));
  const historyExpander = document.querySelector('[data-history-expander]');
  const historySummary = document.querySelector('[data-history-summary]');
  const historyLoading = document.querySelector('[data-history-loading]');
  const historyLoadingSlowMessage = document.querySelector('[data-history-loading-slow]');
  const historyList = document.querySelector('[data-history-list]');
  const generationForms = Array.from(root.querySelectorAll('form[action="/ai-image-generation/generate-image"]'));
  const panels = {
    text: root.querySelector('[data-generation-panel="text"]'),
    edit: root.querySelector('[data-generation-panel="edit"]'),
  };
  const imageViewer = document.querySelector('[data-image-viewer]');
  const imageViewerBackdrop = document.querySelector('[data-image-viewer-backdrop]');
  const imageViewerClose = document.querySelector('[data-image-viewer-close]');
  const imageViewerImage = document.querySelector('[data-image-viewer-image]');
  let generationLocked = false;

  const openAndFocusHistoryExpander = () => {
    if (historyExpander) {
      historyExpander.open = true;
    }
    if (historySummary) {
      try {
        historySummary.focus({ preventScroll: true });
      } catch {
        historySummary.focus();
      }
      historySummary.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  };

  const setMode = (mode) => {
    const nextMode = mode === 'edit' ? 'edit' : 'text';
    if (panels.text) {
      panels.text.hidden = nextMode !== 'text';
    }
    if (panels.edit) {
      panels.edit.hidden = nextMode !== 'edit';
    }

    toggleButtons.forEach((button) => {
      const isActive = button.getAttribute('data-generation-toggle') === nextMode;
      button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      button.classList.toggle('btn-primary', isActive);
      button.classList.toggle('btn-ghost', !isActive);
    });

    try {
      window.localStorage.setItem(STORAGE_KEY, nextMode);
    } catch {
    }
  };

  const setGenerationLocked = (locked) => {
    generationLocked = Boolean(locked);
    toggleButtons.forEach((button) => {
      button.disabled = generationLocked;
    });

    generationForms.forEach((form) => {
      const controls = form.querySelectorAll('button, input, textarea, select');
      controls.forEach((control) => {
        if (control.tagName === 'INPUT' && String(control.type || '').toLowerCase() === 'hidden') {
          return;
        }
        if (control.tagName === 'BUTTON' && String(control.type || '').toLowerCase() === 'submit') {
          const defaultLabel = control.getAttribute('data-default-label') || control.textContent || '';
          const loadingLabel = control.getAttribute('data-loading-label') || defaultLabel;
          control.textContent = generationLocked ? loadingLabel : defaultLabel;
        }
        control.disabled = generationLocked;
      });
    });
  };

  toggleButtons.forEach((button) => {
    button.addEventListener('click', () => {
      setMode(button.getAttribute('data-generation-toggle'));
    });
  });

  const setLoadingState = () => {
    openAndFocusHistoryExpander();
    if (historyLoading) {
      historyLoading.hidden = false;
    }

    window.setTimeout(() => {
      if (historyLoadingSlowMessage) {
        historyLoadingSlowMessage.hidden = false;
      }
    }, 30000);
  };

  const clearLoadingState = () => {
    if (historyLoading) {
      historyLoading.hidden = true;
    }
    if (historyLoadingSlowMessage) {
      historyLoadingSlowMessage.hidden = true;
    }
  };

  const openImageViewer = (src, altText) => {
    if (!imageViewer || !imageViewerImage || !src) {
      return;
    }
    imageViewerImage.src = src;
    imageViewerImage.alt = altText || 'Generated AI image preview';
    imageViewer.hidden = false;
    document.body.style.overflow = 'hidden';
  };

  const closeImageViewer = () => {
    if (!imageViewer || !imageViewerImage) {
      return;
    }
    imageViewer.hidden = true;
    imageViewerImage.src = '';
    document.body.style.overflow = '';
  };

  if (historyList) {
    historyList.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-history-image-trigger]');
      if (!trigger) {
        return;
      }
      openImageViewer(
        String(trigger.getAttribute('data-image-src') || ''),
        String(trigger.getAttribute('data-image-alt') || '')
      );
    });
  }

  if (imageViewerBackdrop) {
    imageViewerBackdrop.addEventListener('click', closeImageViewer);
  }
  if (imageViewerClose) {
    imageViewerClose.addEventListener('click', closeImageViewer);
  }

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && imageViewer && !imageViewer.hidden) {
      closeImageViewer();
    }
  });

  generationForms.forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (generationLocked) {
        return;
      }

      const requestPayload = new FormData(form);
      setGenerationLocked(true);
      setLoadingState();

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          credentials: 'same-origin',
          body: requestPayload,
          headers: {
            'x-discobot-ajax': '1',
            Accept: 'application/json',
          },
        });

        const contentType = String(response.headers.get('content-type') || '').toLowerCase();
        const hasJsonBody = contentType.includes('application/json');
        const result = hasJsonBody ? await response.json().catch(() => null) : null;

        if (result && result.ok) {
          window.location.assign('/ai-image-generation?generate=success');
          return;
        }

        if (result && !result.ok) {
          const nextStatus = String(result.status || 'failed').trim().toLowerCase() || 'failed';
          window.location.assign(`/ai-image-generation?generate=${encodeURIComponent(nextStatus)}`);
          return;
        }

        // Fallback for non-JSON responses (for example, a server-side redirect).
        if (response.redirected && response.url) {
          window.location.assign(response.url);
          return;
        }

        if (!response.ok) {
          window.location.assign('/ai-image-generation?generate=failed');
          return;
        }

        // If we received a 2xx response with no JSON payload, treat as success.
        window.location.assign('/ai-image-generation?generate=success');
        return;
      } catch {
        window.location.assign('/ai-image-generation?generate=failed');
      } finally {
        setGenerationLocked(false);
      }
    });
  });

  let initialMode = 'text';
  try {
    const savedMode = window.localStorage.getItem(STORAGE_KEY);
    if (savedMode === 'edit' || savedMode === 'text') {
      initialMode = savedMode;
    }
  } catch {
  }

  setMode(initialMode);

  if (generationStatus) {
    openAndFocusHistoryExpander();
  }
})();
</script>

<%- include('partials/foot') %>
