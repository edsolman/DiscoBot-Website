<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<main class="container page-section">
  <div class="page-head page-head-branded">
    <div>
      <h1 class="section-icon-title">
        <span class="section-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.8" /><circle cx="9" cy="10" r="2" stroke="currentColor" stroke-width="1.8" /><path d="M6 18l4.5-4.5 3 3L16.5 14 20 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </span>
        <%= t('credits.generate.title', { defaultValue: 'Generate AI Image on Website' }) %>
      </h1>
      <p class="muted"><%= t('credits.generate.subtitle', { defaultValue: 'Use your personal AI credits directly on the website without needing a Discord guild channel.' }) %></p>
      <div class="form-actions" style="margin-top: 10px;">
        <a href="/credits" class="btn btn-ghost"><%= t('nav.aiCredits', { defaultValue: 'AI Credits' }) %></a>
        <a href="/my-account" class="btn btn-ghost btn-with-icon"><span class="btn-icon" aria-hidden="true">←</span><%= t('common.back', { defaultValue: 'Back' }) %></a>
      </div>
    </div>
  </div>

  <% if (generationStatus === 'success') { %>
    <div class="alert success"><%= t('credits.generate.success', { defaultValue: 'AI image generated successfully. 1 credit was used.' }) %></div>
  <% } %>
  <% if (generationStatus === 'no_credits') { %>
    <div class="alert warning"><%= t('credits.generate.noCredits', { defaultValue: 'You do not have enough AI credits to generate an image.' }) %></div>
  <% } %>
  <% if (generationStatus === 'invalid_prompt') { %>
    <div class="alert warning"><%= t('credits.generate.invalidPrompt', { defaultValue: 'Please enter a valid prompt before generating.' }) %></div>
  <% } %>
  <% if (generationStatus === 'invalid_image') { %>
    <div class="alert warning"><%= t('credits.generate.invalidImage', { defaultValue: 'Please upload a valid source image for edit mode.' }) %></div>
  <% } %>
  <% if (generationStatus === 'unavailable') { %>
    <div class="alert warning"><%= t('credits.generate.unavailable', { defaultValue: 'Web image generation is not available right now. Please try again later.' }) %></div>
  <% } %>
  <% if (generationStatus === 'failed') { %>
    <div class="alert warning"><%= t('credits.generate.failed', { defaultValue: 'Image generation failed. Your credit was refunded.' }) %></div>
  <% } %>

  <section class="panel">
    <details class="settings-expander" open>
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
            </span>
            <%= t('credits.yourBalance', { defaultValue: 'Your Balance' }) %>
          </h2>
          <p class="muted"><%= t('credits.balanceSubtitle', { defaultValue: 'Current available credits with purchased and used totals.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <p><strong><%= t('credits.availableCredits', { defaultValue: 'Available credits:' }) %></strong> <%= summary.balance %></p>
        <p class="muted"><%= t('credits.purchasedTotal', { defaultValue: 'Purchased total:' }) %> <%= summary.purchasedTotal %> · <%= t('credits.usedTotal', { defaultValue: 'Used total:' }) %> <%= summary.usedTotal %></p>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander" open>
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.8" /><circle cx="9" cy="10" r="2" stroke="currentColor" stroke-width="1.8" /><path d="M6 18l4.5-4.5 3 3L16.5 14 20 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </span>
            <%= t('credits.generate.title', { defaultValue: 'Generate AI Image on Website' }) %>
          </h2>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <div data-generation-root>
          <div class="generation-loading-overlay" data-generation-loading hidden>
            <div class="generation-loading-card" role="status" aria-live="polite">
              <span class="generation-loading-spinner" aria-hidden="true"></span>
              <div class="generation-loading-text">
                <span><%= t('credits.generate.loadingMessage', { defaultValue: 'Your image is being generated...' }) %></span>
                <span class="generation-loading-slow" data-generation-loading-slow hidden><%= t('credits.generate.loadingSlowMessage', { defaultValue: 'Still working... this can take a little longer for complex requests.' }) %></span>
              </div>
            </div>
          </div>
          <div class="form-actions" style="margin-bottom: 10px;">
            <button type="button" class="btn btn-primary" data-generation-toggle="text" aria-pressed="true">
              <%= t('credits.generate.toggleGenerate', { defaultValue: 'Generate Image' }) %>
            </button>
            <button type="button" class="btn btn-ghost" data-generation-toggle="edit" aria-pressed="false">
              <%= t('credits.generate.toggleEdit', { defaultValue: 'Edit Image' }) %>
            </button>
          </div>

          <div data-generation-panel="text">
            <form method="post" action="/ai-image-generation/generate-image" class="import-form">
              <input type="hidden" name="generation_mode" value="text" />
              <label>
                <%= t('credits.generate.promptLabel', { defaultValue: 'Prompt' }) %>
                <textarea name="prompt" rows="4" maxlength="1500" placeholder="<%= t('credits.generate.promptPlaceholder', { defaultValue: 'Example: A retro-futuristic city skyline at sunset, neon lights, cinematic lighting' }) %>" required></textarea>
              </label>
              <div class="form-actions">
                <button type="submit" class="btn btn-primary"><%= t('credits.generate.button', { defaultValue: 'Generate Image (1 credit)' }) %></button>
              </div>
            </form>
          </div>

          <div data-generation-panel="edit" hidden>
            <form method="post" action="/ai-image-generation/generate-image" enctype="multipart/form-data" class="import-form">
              <input type="hidden" name="generation_mode" value="edit" />
              <label>
                <%= t('credits.generate.sourceImageLabel', { defaultValue: 'Source Image' }) %>
                <input type="file" name="source_image" accept="image/*" required />
              </label>
              <label>
                <%= t('credits.generate.editPromptLabel', { defaultValue: 'Edit Prompt' }) %>
                <textarea name="prompt" rows="3" maxlength="1500" placeholder="<%= t('credits.generate.editPromptPlaceholder', { defaultValue: 'Example: Turn this into a watercolor painting with warm sunset tones' }) %>" required></textarea>
              </label>
              <div class="form-actions">
                <button type="submit" class="btn btn-primary"><%= t('credits.generate.editButton', { defaultValue: 'Edit Image (1 credit)' }) %></button>
              </div>
            </form>
          </div>
        </div>

        <% if (recentWebGenerations && recentWebGenerations.length) { %>
          <div class="purchase-list" style="margin-top: 12px;">
            <% recentWebGenerations.forEach((row) => { %>
              <div class="purchase-item" style="align-items: flex-start; gap: 12px;">
                <img src="/credits/generated/<%= row.id %>" alt="<%= t('credits.generate.generatedImageAlt', { defaultValue: 'Generated AI image' }) %>" style="width: 128px; height: 128px; border-radius: 10px; object-fit: cover; border: 1px solid rgba(255,255,255,0.18);" />
                <div style="min-width: 0;">
                  <div class="muted" style="margin-bottom: 6px;"><%= row.createdAt ? new Date(row.createdAt).toLocaleString() : '' %></div>
                  <div><strong><%= row.prompt %></strong></div>
                  <div class="muted"><%= row.mode === 'edit' ? t('credits.generate.modeEdit', { defaultValue: 'Image edit' }) : t('credits.generate.modeText', { defaultValue: 'Text-to-image' }) %> · <%= row.model %></div>
                  <div class="form-actions" style="margin-top: 8px;">
                    <a href="/credits/generated/<%= row.id %>?download=1" class="btn btn-ghost" download><%= t('credits.generate.download', { defaultValue: 'Download' }) %></a>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </details>
  </section>
</main>

<script>
(() => {
  const root = document.querySelector('[data-generation-root]');
  if (!root) {
    return;
  }

  const STORAGE_KEY = 'discobotCreditsGenerationMode';

  const toggleButtons = Array.from(root.querySelectorAll('[data-generation-toggle]'));
  const loadingOverlay = root.querySelector('[data-generation-loading]');
  const loadingSlowMessage = root.querySelector('[data-generation-loading-slow]');
  const generationForms = Array.from(root.querySelectorAll('form[action="/ai-image-generation/generate-image"]'));
  const panels = {
    text: root.querySelector('[data-generation-panel="text"]'),
    edit: root.querySelector('[data-generation-panel="edit"]'),
  };

  const setMode = (mode) => {
    const nextMode = mode === 'edit' ? 'edit' : 'text';
    if (panels.text) {
      panels.text.hidden = nextMode !== 'text';
    }
    if (panels.edit) {
      panels.edit.hidden = nextMode !== 'edit';
    }

    toggleButtons.forEach((button) => {
      const isActive = button.getAttribute('data-generation-toggle') === nextMode;
      button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      button.classList.toggle('btn-primary', isActive);
      button.classList.toggle('btn-ghost', !isActive);
    });

    try {
      window.localStorage.setItem(STORAGE_KEY, nextMode);
    } catch {
    }
  };

  toggleButtons.forEach((button) => {
    button.addEventListener('click', () => {
      setMode(button.getAttribute('data-generation-toggle'));
    });
  });

  const setLoadingState = () => {
    if (loadingOverlay) {
      loadingOverlay.hidden = false;
      loadingOverlay.classList.add('is-visible');
    }

    root.classList.add('is-generation-loading');

    window.setTimeout(() => {
      if (loadingSlowMessage) {
        loadingSlowMessage.hidden = false;
      }
    }, 30000);
  };

  generationForms.forEach((form) => {
    form.addEventListener('submit', () => {
      setLoadingState();
    });
  });

  let initialMode = 'text';
  try {
    const savedMode = window.localStorage.getItem(STORAGE_KEY);
    if (savedMode === 'edit' || savedMode === 'text') {
      initialMode = savedMode;
    }
  } catch {
  }

  setMode(initialMode);
})();
</script>

<%- include('partials/foot') %>
