<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<main class="container page-section guild-config-page">
  <div class="page-head page-head-branded">
    <div>
      <h1 class="page-title-with-icon">
        <% if (guild.iconUrl) { %>
          <img src="<%= guild.iconUrl %>" alt="<%= guild.name %> logo" class="page-title-guild-icon" />
        <% } else { %>
          <span class="page-title-guild-icon page-title-guild-icon-fallback"><%= guild.name[0] %></span>
        <% } %>
        <span><%= guild.name %></span>
      </h1>
      <h2><%= t('guildConfig.heading', { defaultValue: 'Bot Configuration' }) %></h2>
      <p class="muted"><%= t('guildConfig.subtitle', { defaultValue: 'Edit all DiscoBot features and settings for your server.' }) %></p>
      <div class="form-actions" style="margin-top: 10px;">
        <a href="/dashboard/<%= guild.id %>/leaderboard" class="btn btn-ghost btn-with-icon"><span class="btn-icon" aria-hidden="true">🏆</span><%= t('guildConfig.leaderboard', { defaultValue: 'Leaderboard' }) %></a>
        <a href="/dashboard/<%= guild.id %>/moderation-summary" class="btn btn-ghost btn-with-icon"><span class="btn-icon" aria-hidden="true">🛡️</span><%= t('guildConfig.moderationSummary', { defaultValue: 'Moderation Summary' }) %></a>
        <a href="/my-account" class="btn btn-ghost btn-with-icon"><span class="btn-icon" aria-hidden="true">←</span><%= t('common.back', { defaultValue: 'Back' }) %></a>
      </div>
    </div>
  </div>

  <% if (saved) { %>
    <div class="alert success"><%= t('guildConfig.alerts.saved', { defaultValue: 'Configuration saved successfully.' }) %></div>
  <% } %>
  <% if (imported) { %>
    <div class="alert success"><%= t('guildConfig.alerts.imported', { defaultValue: 'Settings imported successfully.' }) %></div>
  <% } %>
  <% if (moderationWordsStatus === 'added') { %>
    <div class="alert success"><%= t('guildConfig.alerts.wordsAdded', { defaultValue: 'Custom moderation word added.' }) %></div>
  <% } %>
  <% if (moderationWordsStatus === 'removed') { %>
    <div class="alert success"><%= t('guildConfig.alerts.wordsRemoved', { defaultValue: 'Custom moderation word removed.' }) %></div>
  <% } %>
  <% if (moderationWordsStatus === 'exists') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.wordsExists', { defaultValue: 'That custom moderation word is already on the list.' }) %></div>
  <% } %>
  <% if (moderationWordsStatus === 'missing') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.wordsMissing', { defaultValue: 'That custom moderation word was not found.' }) %></div>
  <% } %>
  <% if (moderationWordsStatus === 'invalid') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.wordsInvalid', { defaultValue: 'Please enter a valid word/phrase between 2 and 64 characters.' }) %></div>
  <% } %>
  <% if (scheduleStatus === 'created') { %>
    <div class="alert success"><%= t('guildConfig.alerts.scheduleCreated', { defaultValue: 'Scheduled message created.' }) %></div>
  <% } %>
  <% if (scheduleStatus === 'updated') { %>
    <div class="alert success"><%= t('guildConfig.alerts.scheduleUpdated', { defaultValue: 'Scheduled message updated.' }) %></div>
  <% } %>
  <% if (scheduleStatus === 'deleted') { %>
    <div class="alert success"><%= t('guildConfig.alerts.scheduleDeleted', { defaultValue: 'Scheduled message deleted.' }) %></div>
  <% } %>
  <% if (scheduleStatus === 'missing') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.scheduleMissing', { defaultValue: 'Scheduled message not found.' }) %></div>
  <% } %>
  <% if (scheduleStatus === 'invalid') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.scheduleInvalid', { defaultValue: 'Please provide valid schedule details.' }) %></div>
  <% } %>
  <% if (scheduleStatus === 'past') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.schedulePast', { defaultValue: 'First run must be in the future for the selected timezone.' }) %></div>
  <% } %>
  <% if (translationStatus === 'success') { %>
    <div class="alert success"><%= t('guildConfig.alerts.translationSuccess', { defaultValue: 'Translation subscription checkout completed successfully.' }) %></div>
  <% } %>
  <% if (translationStatus === 'canceled') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.translationCanceled', { defaultValue: 'Translation subscription checkout was canceled.' }) %></div>
  <% } %>
  <% if (translationStatus === 'invalid_plan') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.translationInvalidPlan', { defaultValue: 'Please select a valid translation subscription plan.' }) %></div>
  <% } %>
  <% if (translationStatus === 'no_subscription') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.translationNoSubscription', { defaultValue: 'No active translation subscription found to manage for this guild.' }) %></div>
  <% } %>
  <% if (translationStatus === 'error') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.translationError', { defaultValue: 'Could not process translation subscription request. Please try again.' }) %></div>
  <% } %>
  <% if (aiStatus === 'success') { %>
    <div class="alert success">Guild AI credits purchased successfully.</div>
  <% } %>
  <% if (aiStatus === 'canceled') { %>
    <div class="alert warning">Guild AI checkout was canceled.</div>
  <% } %>
  <% if (aiStatus === 'invalid_pack') { %>
    <div class="alert warning">Please select a valid guild AI credit pack.</div>
  <% } %>
  <% if (aiStatus === 'error') { %>
    <div class="alert warning">Could not process guild AI credit purchase. Please try again.</div>
  <% } %>
  <% if (aiSubStatus === 'success') { %>
    <div class="alert success">Guild AI subscription started successfully.</div>
  <% } %>
  <% if (aiSubStatus === 'canceled') { %>
    <div class="alert warning">Guild AI subscription checkout was canceled.</div>
  <% } %>
  <% if (aiSubStatus === 'invalid_plan') { %>
    <div class="alert warning">Please select a valid guild AI subscription plan.</div>
  <% } %>
  <% if (aiSubStatus === 'no_subscription') { %>
    <div class="alert warning">No active guild AI subscription found to manage.</div>
  <% } %>
  <% if (aiSubStatus === 'error') { %>
    <div class="alert warning">Could not process guild AI subscription request. Please try again.</div>
  <% } %>
  <% if (aiPolicyStatus === 'saved') { %>
    <div class="alert success">Guild AI member credit policy saved.</div>
  <% } %>
  <% if (aiPolicyStatus === 'invalid_member') { %>
    <div class="alert warning">Select a valid guild member before saving an override.</div>
  <% } %>
  <% if (aiPolicyStatus === 'error') { %>
    <div class="alert warning">Could not update guild AI member credit policy.</div>
  <% } %>
  <% if (featureStatus === 'updated') { %>
    <div class="alert success"><%= t('guildConfig.alerts.featureUpdated', { defaultValue: 'Feature settings updated.' }) %></div>
  <% } %>
  <% if (featureStatus === 'error') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.featureError', { defaultValue: 'Could not update feature settings. Please try again.' }) %></div>
  <% } %>
  <% if (featureStatus === 'invalid') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.featureInvalid', { defaultValue: 'Invalid feature selected.' }) %></div>
  <% } %>
  <% if (featureStatus === 'updated' && featureCleanupStatus === 'removed') { %>
    <div class="alert success"><%= t('guildConfig.alerts.featureCleanupRemoved', { defaultValue: 'Associated channel(s) were removed.' }) %></div>
  <% } %>
  <% if (featureStatus === 'updated' && featureCleanupStatus === 'partial') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.featureCleanupPartial', { defaultValue: 'Feature was disabled, but some associated channels could not be removed.' }) %></div>
  <% } %>
  <% if (featureStatus === 'updated' && featureCleanupStatus === 'failed') { %>
    <div class="alert warning"><%= t('guildConfig.alerts.featureCleanupFailed', { defaultValue: 'Feature was disabled, but channel cleanup failed.' }) %></div>
  <% } %>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.8" />
                <path d="M3 10h18" stroke="currentColor" stroke-width="1.8" />
              </svg>
            </span>
            Guild AI Credits
          </h2>
          <p class="muted">Buy guild AI credit packs/subscriptions and control monthly member credit usage limits.</p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <div class="purchase-list">
          <div class="purchase-item">
            <span class="muted">Current guild AI credits balance: <strong><%= Number(aiGuildSummary?.balance || 0).toLocaleString() %></strong></span>
          </div>
        </div>

        <h3>Buy Guild AI Credit Pack</h3>
        <% if (!aiGuildCreditPacks || aiGuildCreditPacks.length === 0) { %>
          <p class="muted">No guild AI credit packs are configured yet.</p>
        <% } else { %>
          <form method="post" action="/dashboard/<%= guild.id %>/ai-credits/checkout" class="credits-packs">
            <% (aiGuildCreditPacks || []).forEach((pack) => { %>
              <button type="submit" name="pack_id" value="<%= pack.id %>" class="btn btn-primary tier-btn">
                <span><%= pack.name %> · +<%= Number(pack.credits || 0).toLocaleString() %> credits · $<%= (Number(pack.unitAmountCents || 0) / 100).toFixed(2) %></span>
              </button>
            <% }) %>
          </form>
        <% } %>

        <h3 style="margin-top: 14px;">Buy Guild AI Subscription</h3>
        <% if (!aiGuildSubscriptionPlans || aiGuildSubscriptionPlans.length === 0) { %>
          <p class="muted">No guild AI subscription plans are configured yet.</p>
        <% } else { %>
          <form method="post" action="/dashboard/<%= guild.id %>/ai-credits/subscribe" class="credits-packs">
            <% (aiGuildSubscriptionPlans || []).forEach((plan) => { %>
              <button type="submit" name="plan_id" value="<%= plan.id %>" class="btn btn-primary tier-btn">
                <span><%= plan.name %> · +<%= Number(plan.creditsPerMonth || 0).toLocaleString() %>/month · $<%= (Number(plan.unitAmountCents || 0) / 100).toFixed(2) %></span>
              </button>
            <% }) %>
          </form>
        <% } %>

        <% if (aiGuildSubscriptions && aiGuildSubscriptions.length > 0) { %>
          <div class="purchase-list" style="margin-top: 12px;">
            <% aiGuildSubscriptions.forEach((row) => { %>
              <div class="purchase-item analytics-purchase-item">
                <div>
                  <strong><%= row.planId %></strong>
                  <div class="muted">
                    +<%= Number(row.creditsPerMonth || 0).toLocaleString() %>/month · Status: <%= row.status %>
                    <% if (row.cancelAtPeriodEnd) { %>
                      · Cancels at period end
                    <% } %>
                    <% if (row.currentPeriodEnd) { %>
                      · Period end: <%= new Date(row.currentPeriodEnd).toLocaleString() %>
                    <% } %>
                  </div>
                </div>
                <div class="form-actions" style="margin:0;">
                  <form method="post" action="/dashboard/<%= guild.id %>/ai-credits/subscription/manage">
                    <input type="hidden" name="stripe_subscription_id" value="<%= row.stripeSubscriptionId %>" />
                    <button type="submit" class="btn btn-ghost">Manage in Stripe</button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

        <hr style="margin: 16px 0; border: 0; border-top: 1px solid rgba(255,255,255,0.12);" />

        <h3>Member AI Credit Allocation</h3>
        <p class="muted">Set a default monthly credit cap per guild member and optional per-member overrides.</p>

        <form method="post" action="/dashboard/<%= guild.id %>/ai-credits/policy/default" class="level-rows">
          <div class="level-row">
            <label>
              Default monthly credits per member
              <input type="number" name="default_monthly_credits_per_member" min="0" value="<%= Number(guildAiCreditPolicy?.default_monthly_credits_per_member || 0) %>" required />
            </label>
            <div class="form-actions" style="align-self: end; margin: 0;">
              <button type="submit" class="btn btn-primary">Save Default Limit</button>
            </div>
          </div>
        </form>

        <form method="post" action="/dashboard/<%= guild.id %>/ai-credits/policy/override/upsert" class="level-rows" id="aiMemberOverrideForm" style="margin-top:10px;">
          <div class="level-row">
            <label style="position:relative;">
              Search member
              <input type="text" id="aiMemberSearchInput" placeholder="Type at least 2 characters..." autocomplete="off" />
              <div id="aiMemberSearchResults" class="member-search-results" style="position:absolute; left:0; right:0; z-index:20; margin-top:6px; max-height:240px; overflow:auto;" hidden></div>
            </label>
            <label>
              Selected member ID
              <input type="text" id="aiMemberIdDisplay" readonly placeholder="No member selected" />
              <input type="hidden" name="member_user_id" id="aiMemberUserId" />
              <input type="hidden" name="member_username" id="aiMemberUsername" />
            </label>
            <label>
              Monthly credits for this member
              <input type="number" name="member_monthly_credits_per_month" min="0" value="0" required />
            </label>
            <div class="form-actions" style="align-self: end; margin: 0;">
              <button type="submit" class="btn btn-primary">Add/Update Override</button>
            </div>
          </div>
        </form>

        <% if (guildAiCreditPolicy && guildAiCreditPolicy.member_overrides && guildAiCreditPolicy.member_overrides.length > 0) { %>
          <div class="purchase-list" style="margin-top: 10px;">
            <% guildAiCreditPolicy.member_overrides.forEach((row) => { %>
              <div class="purchase-item analytics-purchase-item">
                <div>
                  <strong><%= row.username %></strong>
                  <div class="muted">User ID: <%= row.user_id %> · Monthly credits: <%= Number(row.monthly_credits_per_month || 0).toLocaleString() %></div>
                </div>
                <form method="post" action="/dashboard/<%= guild.id %>/ai-credits/policy/override/remove">
                  <input type="hidden" name="member_user_id" value="<%= row.user_id %>" />
                  <button type="submit" class="btn btn-ghost">Remove</button>
                </form>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="muted">No member-specific overrides configured yet.</p>
        <% } %>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="3" y="4" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.8" />
                <path d="M3 9h18M12 9v11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            </span>
            <%= t('guildConfig.featureControls', { defaultValue: 'Feature Controls' }) %>
          </h2>
          <p class="muted"><%= t('guildConfig.featureControlsHelp', { defaultValue: 'Enable or disable guild features. When disabling selected features, you can optionally remove related DiscoBot channels.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <form method="post" action="/dashboard/<%= guild.id %>/features" class="feature-controls-list">
      <% (featureControls || []).forEach((feature) => { %>
        <div class="feature-control-card">
          <div>
            <strong><%= feature.label %></strong>
            <p class="muted feature-control-desc"><%= feature.description %></p>
          </div>

          <label class="feature-slider-label">
            <span class="feature-slider-text"><%= t('common.enabled', { defaultValue: 'Enabled' }) %></span>
            <input class="feature-enabled-input" type="checkbox" name="enabled_<%= feature.key %>" value="1" <%= feature.enabled ? 'checked' : '' %> />
            <span class="feature-slider" aria-hidden="true"></span>
          </label>

          <% if (feature.cleanupSupported) { %>
            <label class="feature-cleanup-label <%= feature.enabled ? 'feature-cleanup-hidden' : '' %>">
              <input type="checkbox" name="remove_channels_<%= feature.key %>" value="1" />
              <span><%= t('guildConfig.cleanupPromptPrefix', { defaultValue: 'Do you also want to remove the associated channel' }) %> #<%= feature.cleanupChannelName %>?</span>
            </label>
          <% } %>

        </div>
      <% }) %>

          <div class="form-actions" style="margin-top:10px;">
            <button type="submit" class="btn btn-primary"><%= t('guildConfig.saveFeatureSettings', { defaultValue: 'Save Feature Settings' }) %></button>
          </div>
        </form>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z" stroke="currentColor" stroke-width="1.8" />
                <path d="M3 12h18M12 3c2.2 2.2 3.5 5.4 3.5 9S14.2 18.8 12 21M12 3c-2.2 2.2-3.5 5.4-3.5 9S9.8 18.8 12 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            </span>
            <%= t('guildConfig.translationCharacterLimit', { defaultValue: 'Translation Character Limit' }) %>
          </h2>
          <p class="muted"><%= t('guildConfig.translationCharacterLimitHelp', { defaultValue: 'Free usage and paid translation add-ons are managed per guild and reset monthly.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <div class="purchase-list">
      <div class="purchase-item">
        <span class="muted"><%= t('guildConfig.translationSummary.freeLimit', { defaultValue: 'Free limit' }) %>: <strong><%= Number(translationSummary?.freeLimit || 0).toLocaleString() %></strong></span>
        <span class="muted"><%= t('guildConfig.translationSummary.currentAllowance', { defaultValue: 'Current allowance' }) %>: <strong><%= Number(translationSummary?.allowance || 0).toLocaleString() %></strong></span>
        <span class="muted"><%= t('guildConfig.translationSummary.usedThisMonth', { defaultValue: 'Used this month' }) %>: <strong><%= Number(translationSummary?.monthlyUsage || 0).toLocaleString() %></strong></span>
        <span class="muted"><%= t('guildConfig.translationSummary.remaining', { defaultValue: 'Remaining' }) %>: <strong><%= Number(translationSummary?.remainingCharacters || 0).toLocaleString() %></strong></span>
      </div>
        </div>

    <% if (!translationSubscriptionPlans || translationSubscriptionPlans.length === 0) { %>
      <p class="muted"><%= t('guildConfig.noTranslationPlans', { defaultValue: 'No translation subscription plans are configured yet.' }) %></p>
    <% } else { %>
      <% const translationBasePlan = translationSubscriptionPlans[0] || null; %>
      <% const translationBaseChars = Number(translationBasePlan?.charactersPerMonth || 0); %>
      <% const translationBaseCents = Number(translationBasePlan?.unitAmountCents || 0); %>
      <% const translationBaseRate = translationBaseChars > 0 ? (translationBaseCents / translationBaseChars) : 0; %>
      <form method="post" action="/dashboard/<%= guild.id %>/translation/subscribe" class="credits-packs">
        <% (translationSubscriptionPlans || []).forEach((plan, index) => { %>
          <% const planChars = Number(plan.charactersPerMonth || 0); %>
          <% const planCents = Number(plan.unitAmountCents || 0); %>
          <% const planRate = planChars > 0 ? (planCents / planChars) : 0; %>
          <% const translationSavingsPercent = (index > 0 && translationBaseRate > 0 && planRate > 0)
            ? Math.max(0, Math.round((1 - (planRate / translationBaseRate)) * 100))
            : 0; %>
          <button type="submit" name="translation_plan_id" value="<%= plan.id %>" class="btn btn-primary tier-btn">
            <span><%= plan.name %> · +<%= Number(plan.charactersPerMonth || 0).toLocaleString() %>/month · $<%= (Number(plan.unitAmountCents || 0) / 100).toFixed(2) %></span>
            <% if (translationSavingsPercent > 0) { %>
              <span class="tier-saving-badge"><%= translationSavingsPercent %>% <%= t('common.saving', { defaultValue: 'saving' }) %></span>
            <% } %>
          </button>
        <% }) %>
      </form>
    <% } %>

        <% if (translationSubscriptions && translationSubscriptions.length > 0) { %>
      <div class="purchase-list">
        <% translationSubscriptions.forEach((row) => { %>
          <div class="purchase-item analytics-purchase-item">
            <div>
              <strong><%= row.planId %></strong>
              <div class="muted">
                +<%= Number(row.charactersPerMonth || 0).toLocaleString() %>/month ·
                <%= t('guildConfig.statusLabel', { defaultValue: 'Status' }) %>: <%= row.status %>
                <% if (row.cancelAtPeriodEnd) { %>
                  · <%= t('guildConfig.cancelsAtPeriodEnd', { defaultValue: 'Cancels at period end' }) %>
                <% } %>
                <% if (row.currentPeriodEnd) { %>
                  · <%= t('guildConfig.periodEnd', { defaultValue: 'Period end' }) %>: <%= new Date(row.currentPeriodEnd).toLocaleString() %>
                <% } %>
              </div>
            </div>
            <div class="form-actions" style="margin:0;">
              <form method="post" action="/dashboard/<%= guild.id %>/translation/subscription/manage">
                <input type="hidden" name="stripe_subscription_id" value="<%= row.stripeSubscriptionId %>" />
                <button type="submit" class="btn btn-ghost"><%= t('guildConfig.manageInStripe', { defaultValue: 'Manage in Stripe' }) %></button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
        <% } else { %>
      <p class="muted"><%= t('guildConfig.noActiveTranslationSubs', { defaultValue: 'No active translation subscriptions for this guild yet.' }) %></p>
        <% } %>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M8 5h8v3a4 4 0 0 1-8 0V5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M6 7H4a2 2 0 0 0 2 2M18 7h2a2 2 0 0 1-2 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M12 12v3M9 20h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <%= t('guildConfig.gamificationLevels', { defaultValue: 'Gamification Levels' }) %>
          </h2>
          <p class="muted"><%= t('guildConfig.gamificationLevelsHelp', { defaultValue: 'Set level number, level name, and XP required to reach each level.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <form method="post" action="/dashboard/<%= guild.id %>/levels" id="levelsForm">
      <div id="levelRows" class="level-rows">
        <% levels.forEach((row) => { %>
          <div class="level-row">
            <label>
              <%= t('guildConfig.levels.level', { defaultValue: 'Level' }) %>
              <input type="number" name="level" value="<%= row.level %>" min="0" max="100" required />
            </label>
            <label>
              <%= t('guildConfig.levels.levelName', { defaultValue: 'Level Name' }) %>
              <input type="text" name="level_name" value="<%= row.name %>" maxlength="24" required />
            </label>
            <label>
              <%= t('guildConfig.levels.xpRequired', { defaultValue: 'XP Required' }) %>
              <input type="number" name="interactions_required" value="<%= row.interactions_required %>" min="0" required />
            </label>
            <button type="button" class="btn btn-ghost remove-row"><%= t('common.remove', { defaultValue: 'Remove' }) %></button>
          </div>
        <% }) %>
      </div>

          <div class="form-actions">
            <button type="button" id="addRowBtn" class="btn btn-ghost"><%= t('guildConfig.levels.addLevel', { defaultValue: 'Add Level' }) %></button>
            <button type="submit" class="btn btn-primary"><%= t('guildConfig.levels.saveLevels', { defaultValue: 'Save Levels' }) %></button>
          </div>
        </form>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M12 3l7 3v5c0 4.3-2.5 8.2-7 10-4.5-1.8-7-5.7-7-10V6l7-3z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9.6 12.2l1.7 1.7 3.4-3.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <%= t('guildConfig.customModerationWords.title', { defaultValue: 'Custom Moderation Words' }) %>
          </h2>
          <p class="muted"><%= t('guildConfig.customModerationWords.subtitle', { defaultValue: "Add custom words/phrases for this guild. These are checked in addition to DiscoBot's default moderation terms." }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <form method="post" action="/dashboard/<%= guild.id %>/moderation-words/add" class="import-form">
      <label>
        <%= t('guildConfig.customModerationWords.addLabel', { defaultValue: 'Add Word/Phrase' }) %>
        <input type="text" name="word" maxlength="64" placeholder="<%= t('guildConfig.customModerationWords.placeholder', { defaultValue: 'e.g. toxic phrase' }) %>" required />
      </label>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><%= t('guildConfig.customModerationWords.addButton', { defaultValue: 'Add Custom Word' }) %></button>
      </div>
    </form>

        <% if (!customModerationTerms || customModerationTerms.length === 0) { %>
      <p class="muted"><%= t('guildConfig.customModerationWords.none', { defaultValue: 'No custom moderation words configured yet.' }) %></p>
        <% } else { %>
      <div class="purchase-list">
        <% customModerationTerms.forEach((term) => { %>
          <div class="purchase-item">
            <span><strong><%= term %></strong></span>
            <form method="post" action="/dashboard/<%= guild.id %>/moderation-words/remove">
              <input type="hidden" name="word" value="<%= term %>" />
              <button type="submit" class="btn btn-ghost"><%= t('common.remove', { defaultValue: 'Remove' }) %></button>
            </form>
          </div>
        <% }) %>
      </div>
        <% } %>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M12 3l7 3v5c0 4.3-2.5 8.2-7 10-4.5-1.8-7-5.7-7-10V6l7-3z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9.6 12.2l1.7 1.7 3.4-3.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <%= t('guildConfig.moderationSnapshot.title', { defaultValue: 'Moderation Snapshot' }) %>
          </h2>
          <p class="muted"><%= t('guildConfig.moderationSnapshot.subtitle', { defaultValue: 'Quick view of top moderated users and action totals. Use the full summary for deeper analysis.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <div class="purchase-list">
      <div class="purchase-item">
        <span class="muted"><%= t('guildConfig.moderationSnapshot.flagged', { defaultValue: 'Flagged' }) %>: <strong><%= Number(moderationSnapshotTotals?.flagged || 0) %></strong></span>
        <span class="muted"><%= t('guildConfig.moderationSnapshot.approved', { defaultValue: 'Approved' }) %>: <strong><%= Number(moderationSnapshotTotals?.approved || 0) %></strong></span>
        <span class="muted"><%= t('guildConfig.moderationSnapshot.rejected', { defaultValue: 'Rejected' }) %>: <strong><%= Number(moderationSnapshotTotals?.rejected || 0) %></strong></span>
        <span class="muted"><%= t('guildConfig.moderationSnapshot.kicked', { defaultValue: 'Kicked' }) %>: <strong><%= Number(moderationSnapshotTotals?.kicked || 0) %></strong></span>
        <span class="muted"><%= t('guildConfig.moderationSnapshot.banned', { defaultValue: 'Banned' }) %>: <strong><%= Number(moderationSnapshotTotals?.banned || 0) %></strong></span>
      </div>
      </div>

        <% if (!topModeratedUsers || topModeratedUsers.length === 0) { %>
      <p class="muted"><%= t('guildConfig.moderationSnapshot.none', { defaultValue: 'No moderation activity recorded yet.' }) %></p>
        <% } else { %>
      <div class="purchase-list">
        <% topModeratedUsers.forEach((row) => { %>
          <div class="purchase-item analytics-purchase-item">
            <div>
              <strong>
                <% if (row.userIdDisplay) { %>
                  <a href="https://discord.com/users/<%= row.userIdDisplay %>" target="_blank" rel="noopener noreferrer"><%= row.username %></a>
                <% } else { %>
                  <%= row.username %>
                <% } %>
              </strong>
              <div class="muted">
                <% if (row.userIdDisplay) { %>
                  <%= t('guildConfig.moderationSnapshot.userIdLabel', { defaultValue: 'ID' }) %>: <%= row.userIdDisplay %>
                <% } %>
              </div>
            </div>
            <div class="muted analytics-right">
              <div><%= t('guildConfig.moderationSnapshot.flagged', { defaultValue: 'Flagged' }) %>: <strong><%= row.moderationFlagCount %></strong></div>
              <div><%= t('guildConfig.moderationSnapshot.approved', { defaultValue: 'Approved' }) %>: <strong><%= row.moderationApprovedCount %></strong></div>
              <div><%= t('guildConfig.moderationSnapshot.rejected', { defaultValue: 'Rejected' }) %>: <strong><%= row.moderationRejectedCount %></strong></div>
              <div><%= t('guildConfig.moderationSnapshot.kicked', { defaultValue: 'Kicked' }) %>: <strong><%= row.moderationKickCount %></strong></div>
              <div><%= t('guildConfig.moderationSnapshot.banned', { defaultValue: 'Banned' }) %>: <strong><%= row.moderationBanCount %></strong></div>
            </div>
          </div>
        <% }) %>
      </div>
        <% } %>

        <div class="form-actions">
          <a href="/dashboard/<%= guild.id %>/moderation-summary" class="btn btn-ghost"><%= t('guildConfig.moderationSnapshot.openFull', { defaultValue: 'Open Full Moderation Summary' }) %></a>
        </div>
      </div>
    </details>
  </section>

  <section class="panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2 class="section-icon-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="3" y="5" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.8" />
                <path d="M8 3v4M16 3v4M3 10h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                <path d="M12 14v3l2 1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <%= t('guildConfig.scheduledMessages', { defaultValue: 'Scheduled Messages' }) %>
          </h2>
          <p class="muted"><%= t('guildConfig.scheduledMessagesHelp', { defaultValue: 'Create and manage automatic server messages. Choose a timezone per schedule.' }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
    <% const normalizedScheduleTimezoneOptions = (Array.isArray(scheduleTimezoneOptions) ? scheduleTimezoneOptions : [])
      .map((entry) => {
        if (typeof entry === 'string') {
          return { name: entry, label: entry };
        }
        if (entry && typeof entry === 'object') {
          const name = String(entry.name || '').trim();
          const label = String(entry.label || name).trim();
          if (name) {
            return { name, label: label || name };
          }
        }
        return null;
      })
      .filter(Boolean); %>
    <% const scheduleTimezoneSelectOptions = normalizedScheduleTimezoneOptions.length > 0
      ? normalizedScheduleTimezoneOptions
      : [{ name: 'UTC', label: '(UTC+00:00) UTC' }]; %>

    <details class="schedule-expander schedule-create-expander">
      <summary>
        <span><%= t('guildConfig.scheduleForm.create', { defaultValue: 'Create Scheduled Message' }) %></span>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="schedule-expander-body">
        <form method="post" action="/dashboard/<%= guild.id %>/schedules/create" class="import-form">
          <div class="level-rows">
            <div class="level-row schedule-row">
              <label class="field-channel">
                <%= t('guildConfig.scheduleForm.channel', { defaultValue: 'Channel' }) %>
                <select name="channel_id" required>
                  <% (guildTextChannels || []).forEach((channel) => { %>
                    <option value="<%= channel.id %>">#<%= channel.name %></option>
                  <% }) %>
                </select>
              </label>
              <label class="field-frequency">
                <%= t('guildConfig.scheduleForm.frequency', { defaultValue: 'Frequency' }) %>
                <select name="recurrence" required>
                  <option value="once"><%= t('guildConfig.scheduleForm.once', { defaultValue: 'Once' }) %></option>
                  <option value="daily"><%= t('guildConfig.scheduleForm.daily', { defaultValue: 'Daily' }) %></option>
                  <option value="weekly"><%= t('guildConfig.scheduleForm.weekly', { defaultValue: 'Weekly' }) %></option>
                </select>
              </label>
              <label class="field-timezone">
                <%= t('guildConfig.scheduleForm.timezone', { defaultValue: 'Timezone' }) %>
                <select name="timezone_name" required>
                  <% scheduleTimezoneSelectOptions.forEach((tz) => { %>
                    <option value="<%= tz.name %>" <%= tz.name === 'UTC' ? 'selected' : '' %>><%= tz.label %></option>
                  <% }) %>
                </select>
              </label>
              <label class="field-custom-timezone">
                <%= t('guildConfig.scheduleForm.customTimezone', { defaultValue: 'Custom Timezone (optional)' }) %>
                <input type="text" name="custom_timezone_name" placeholder="<%= t('guildConfig.scheduleForm.customTimezonePlaceholder', { defaultValue: 'e.g. Pacific/Auckland' }) %>" />
              </label>
              <label class="field-next-run">
                <%= t('guildConfig.scheduleForm.dateTimeToSend', { defaultValue: 'Date & Time to Send' }) %>
                <input type="datetime-local" name="once_run_at" class="schedule-once-input" required />
              </label>
              <label class="field-start-date">
                <%= t('guildConfig.scheduleForm.startDate', { defaultValue: 'Start Date' }) %>
                <input type="date" name="start_date" class="schedule-start-date" required />
              </label>
              <label class="field-send-time">
                <%= t('guildConfig.scheduleForm.sendTime', { defaultValue: 'Time to Send' }) %>
                <input type="time" name="send_time" class="schedule-send-time" required />
              </label>
              <label class="field-weekdays">
                <%= t('guildConfig.scheduleForm.daysOfWeek', { defaultValue: 'Days of Week' }) %>
                <div class="schedule-weekdays">
                  <label><input type="checkbox" name="weekly_days" value="mon" /><%= t('guildConfig.scheduleForm.weekdays.mon', { defaultValue: 'Mon' }) %></label>
                  <label><input type="checkbox" name="weekly_days" value="tue" /><%= t('guildConfig.scheduleForm.weekdays.tue', { defaultValue: 'Tue' }) %></label>
                  <label><input type="checkbox" name="weekly_days" value="wed" /><%= t('guildConfig.scheduleForm.weekdays.wed', { defaultValue: 'Wed' }) %></label>
                  <label><input type="checkbox" name="weekly_days" value="thu" /><%= t('guildConfig.scheduleForm.weekdays.thu', { defaultValue: 'Thu' }) %></label>
                  <label><input type="checkbox" name="weekly_days" value="fri" /><%= t('guildConfig.scheduleForm.weekdays.fri', { defaultValue: 'Fri' }) %></label>
                  <label><input type="checkbox" name="weekly_days" value="sat" /><%= t('guildConfig.scheduleForm.weekdays.sat', { defaultValue: 'Sat' }) %></label>
                  <label><input type="checkbox" name="weekly_days" value="sun" /><%= t('guildConfig.scheduleForm.weekdays.sun', { defaultValue: 'Sun' }) %></label>
                </div>
              </label>
              <label class="field-end-date">
                <%= t('guildConfig.scheduleForm.endDateOptional', { defaultValue: 'End Date (optional)' }) %>
                <input type="date" name="end_date" />
              </label>
            </div>
          </div>
          <label>
            <%= t('guildConfig.scheduleForm.messageContent', { defaultValue: 'Message Content' }) %>
            <textarea name="message_content" maxlength="1800" rows="4" required placeholder="<%= t('guildConfig.scheduleForm.messagePlaceholder', { defaultValue: 'Your scheduled message' }) %>"></textarea>
          </label>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= t('guildConfig.scheduleForm.create', { defaultValue: 'Create Scheduled Message' }) %></button>
          </div>
          <p class="muted helper-text"><%= t('guildConfig.scheduleForm.timezoneHelpPrefix', { defaultValue: 'Timezone format uses IANA names (example:' }) %> <strong>Europe/London</strong>). <%= t('guildConfig.scheduleForm.timezoneHelpSee', { defaultValue: 'See' }) %> <a href="https://en.wikipedia.org/wiki/List_of_tz_database_time_zones" target="_blank" rel="noopener noreferrer"><%= t('guildConfig.scheduleForm.timezoneListLabel', { defaultValue: 'timezone list' }) %></a>.</p>
        </form>
      </div>
    </details>

    <h3 class="schedule-subheading"><%= t('guildConfig.scheduleForm.viewEditTitle', { defaultValue: 'View/Edit Scheduled Messages' }) %></h3>

    <% if (!scheduledMessages || scheduledMessages.length === 0) { %>
      <p class="muted"><%= t('guildConfig.scheduleForm.none', { defaultValue: 'No scheduled messages configured yet.' }) %></p>
    <% } else { %>
      <div class="purchase-list">
        <% scheduledMessages.forEach((row) => { %>
          <% const rowChannelId = String(row.channel_id_display || row.channel_id || ''); %>
          <% const messagePreviewRaw = String(row.message_content || '').replace(/\s+/g, ' ').trim(); %>
          <% const messagePreview = messagePreviewRaw.length > 72 ? `${messagePreviewRaw.slice(0, 72)}…` : (messagePreviewRaw || t('guildConfig.scheduleForm.noMessageContent', { defaultValue: '(No message content)' })); %>
          <% const recurrenceLabel = String(row.recurrence || 'once'); %>
          <% const recurrenceDisplay = recurrenceLabel === 'daily'
            ? t('guildConfig.scheduleForm.daily', { defaultValue: 'Daily' })
            : recurrenceLabel === 'weekly'
              ? t('guildConfig.scheduleForm.weekly', { defaultValue: 'Weekly' })
              : t('guildConfig.scheduleForm.once', { defaultValue: 'Once' }); %>
          <% const nextRunDisplay = row.next_run_at ? new Date(row.next_run_at).toLocaleString() : t('guildConfig.scheduleForm.noNextRun', { defaultValue: 'No next run' }); %>
          <% const isActive = Boolean(row.active); %>
          <details class="schedule-expander schedule-item-expander">
            <summary>
              <span class="schedule-item-summary-title"><%= messagePreview %></span>
              <span class="schedule-item-summary-right">
                <span class="schedule-item-summary-meta"><%= recurrenceDisplay %> · <%= t('guildConfig.scheduleForm.nextRunLabel', { defaultValue: 'Next Run' }) %>: <%= nextRunDisplay %></span>
                <span class="schedule-status-pill <%= isActive ? 'is-active' : 'is-paused' %>"><%= isActive ? t('guildConfig.scheduleForm.active', { defaultValue: 'Active' }) : t('guildConfig.scheduleForm.paused', { defaultValue: 'Paused' }) %></span>
                <span class="schedule-expander-plus" aria-hidden="true">+</span>
              </span>
            </summary>
            <div class="schedule-expander-body">
              <div class="purchase-item" style="display:block;">
                <form method="post" action="/dashboard/<%= guild.id %>/schedules/<%= encodeURIComponent(row.schedule_id) %>/update" class="import-form">
                  <div class="level-rows">
                    <div class="level-row schedule-row">
                  <label class="field-channel">
                    <%= t('guildConfig.scheduleForm.channel', { defaultValue: 'Channel' }) %>
                    <select name="channel_id" required>
                      <% (guildTextChannels || []).forEach((channel) => { %>
                        <option value="<%= channel.id %>" <%= String(channel.id) === rowChannelId ? 'selected' : '' %>>#<%= channel.name %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label class="field-frequency">
                    <%= t('guildConfig.scheduleForm.frequency', { defaultValue: 'Frequency' }) %>
                    <select name="recurrence" required>
                      <option value="once" <%= row.recurrence === 'once' ? 'selected' : '' %>><%= t('guildConfig.scheduleForm.once', { defaultValue: 'Once' }) %></option>
                      <option value="daily" <%= row.recurrence === 'daily' ? 'selected' : '' %>><%= t('guildConfig.scheduleForm.daily', { defaultValue: 'Daily' }) %></option>
                      <option value="weekly" <%= row.recurrence === 'weekly' ? 'selected' : '' %>><%= t('guildConfig.scheduleForm.weekly', { defaultValue: 'Weekly' }) %></option>
                    </select>
                  </label>
                  <label class="field-timezone">
                    <%= t('guildConfig.scheduleForm.timezone', { defaultValue: 'Timezone' }) %>
                    <select name="timezone_name" required>
                      <% scheduleTimezoneSelectOptions.forEach((tz) => { %>
                        <option value="<%= tz.name %>" <%= String(row.timezone_name || 'UTC') === tz.name ? 'selected' : '' %>><%= tz.label %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label class="field-custom-timezone">
                    <%= t('guildConfig.scheduleForm.customTimezone', { defaultValue: 'Custom Timezone (optional)' }) %>
                    <input type="text" name="custom_timezone_name" value="<%= scheduleTimezoneSelectOptions.some((tz) => String(tz.name || '') === String(row.timezone_name || 'UTC')) ? '' : String(row.timezone_name || '') %>" placeholder="<%= t('guildConfig.scheduleForm.customTimezonePlaceholder', { defaultValue: 'e.g. Pacific/Auckland' }) %>" />
                  </label>
                  <label class="field-next-run">
                    <%= t('guildConfig.scheduleForm.dateTimeToSend', { defaultValue: 'Date & Time to Send' }) %>
                    <input type="datetime-local" name="once_run_at" class="schedule-once-input" value="<%= row.once_run_at_local || toDateTimeLocalInputInTimeZone(row.next_run_at, row.timezone_name || 'UTC') %>" required />
                  </label>
                  <label class="field-start-date">
                    <%= t('guildConfig.scheduleForm.startDate', { defaultValue: 'Start Date' }) %>
                    <input type="date" name="start_date" class="schedule-start-date" value="<%= row.start_date_text || '' %>" required />
                  </label>
                  <label class="field-send-time">
                    <%= t('guildConfig.scheduleForm.sendTime', { defaultValue: 'Time to Send' }) %>
                    <input type="time" name="send_time" class="schedule-send-time" value="<%= row.send_time_text || '' %>" required />
                  </label>
                  <label class="field-weekdays">
                    <%= t('guildConfig.scheduleForm.daysOfWeek', { defaultValue: 'Days of Week' }) %>
                    <% const rowWeeklyDays = Array.isArray(row.weekly_days) ? row.weekly_days : []; %>
                    <div class="schedule-weekdays">
                      <label><input type="checkbox" name="weekly_days" value="mon" <%= rowWeeklyDays.includes('mon') ? 'checked' : '' %> /><%= t('guildConfig.scheduleForm.weekdays.mon', { defaultValue: 'Mon' }) %></label>
                      <label><input type="checkbox" name="weekly_days" value="tue" <%= rowWeeklyDays.includes('tue') ? 'checked' : '' %> /><%= t('guildConfig.scheduleForm.weekdays.tue', { defaultValue: 'Tue' }) %></label>
                      <label><input type="checkbox" name="weekly_days" value="wed" <%= rowWeeklyDays.includes('wed') ? 'checked' : '' %> /><%= t('guildConfig.scheduleForm.weekdays.wed', { defaultValue: 'Wed' }) %></label>
                      <label><input type="checkbox" name="weekly_days" value="thu" <%= rowWeeklyDays.includes('thu') ? 'checked' : '' %> /><%= t('guildConfig.scheduleForm.weekdays.thu', { defaultValue: 'Thu' }) %></label>
                      <label><input type="checkbox" name="weekly_days" value="fri" <%= rowWeeklyDays.includes('fri') ? 'checked' : '' %> /><%= t('guildConfig.scheduleForm.weekdays.fri', { defaultValue: 'Fri' }) %></label>
                      <label><input type="checkbox" name="weekly_days" value="sat" <%= rowWeeklyDays.includes('sat') ? 'checked' : '' %> /><%= t('guildConfig.scheduleForm.weekdays.sat', { defaultValue: 'Sat' }) %></label>
                      <label><input type="checkbox" name="weekly_days" value="sun" <%= rowWeeklyDays.includes('sun') ? 'checked' : '' %> /><%= t('guildConfig.scheduleForm.weekdays.sun', { defaultValue: 'Sun' }) %></label>
                    </div>
                  </label>
                  <label class="field-end-date">
                    <%= t('guildConfig.scheduleForm.endDateOptional', { defaultValue: 'End Date (optional)' }) %>
                    <input type="date" name="end_date" value="<%= row.end_date_text || '' %>" />
                  </label>
                  <label class="field-status">
                    <%= t('guildConfig.statusLabel', { defaultValue: 'Status' }) %>
                    <select name="active" required>
                      <option value="true" <%= row.active ? 'selected' : '' %>><%= t('guildConfig.scheduleForm.active', { defaultValue: 'Active' }) %></option>
                      <option value="false" <%= !row.active ? 'selected' : '' %>><%= t('guildConfig.scheduleForm.paused', { defaultValue: 'Paused' }) %></option>
                    </select>
                  </label>
                </div>
              </div>
                  <label>
                    <%= t('guildConfig.scheduleForm.messageContent', { defaultValue: 'Message Content' }) %>
                    <textarea name="message_content" maxlength="1800" rows="3" required><%= row.message_content %></textarea>
                  </label>
                  <div class="form-actions">
                    <button type="submit" class="btn btn-primary"><%= t('guildConfig.scheduleForm.save', { defaultValue: 'Save Schedule' }) %></button>
                  </div>
                  <p class="muted helper-text"><%= t('guildConfig.scheduleForm.timezoneHelpPrefix', { defaultValue: 'Timezone format uses IANA names (example:' }) %> <strong>Europe/London</strong>). <%= t('guildConfig.scheduleForm.timezoneHelpSee', { defaultValue: 'See' }) %> <a href="https://en.wikipedia.org/wiki/List_of_tz_database_time_zones" target="_blank" rel="noopener noreferrer"><%= t('guildConfig.scheduleForm.timezoneListLabel', { defaultValue: 'timezone list' }) %></a>.</p>
                  <p class="muted helper-text"><%= t('guildConfig.scheduleForm.scheduleIdLabel', { defaultValue: 'Schedule ID' }) %>: <strong><%= row.schedule_id %></strong> · <%= t('guildConfig.scheduleForm.timezone', { defaultValue: 'Timezone' }) %>: <strong><%= row.timezone_name || 'UTC' %></strong> · <%= t('guildConfig.scheduleForm.runsSentLabel', { defaultValue: 'Runs sent' }) %>: <strong><%= Number(row.run_count || 0) %></strong> · <%= t('guildConfig.scheduleForm.lastRunLabel', { defaultValue: 'Last run' }) %>: <strong><%= row.last_run_at ? new Date(row.last_run_at).toLocaleString() : t('guildConfig.scheduleForm.never', { defaultValue: 'Never' }) %></strong></p>
                </form>

                <form method="post" action="/dashboard/<%= guild.id %>/schedules/<%= encodeURIComponent(row.schedule_id) %>/delete">
                  <button type="submit" class="btn btn-ghost"><%= t('guildConfig.scheduleForm.delete', { defaultValue: 'Delete Schedule' }) %></button>
                </form>
              </div>
            </div>
          </details>
        <% }) %>
      </div>
    <% } %>
      </div>
    </details>
  </section>

  <section class="panel import-export-panel">
    <details class="settings-expander">
      <summary class="settings-expander-summary">
        <div class="settings-expander-summary-main">
          <h2><%= t('guildConfig.importExport.title', { defaultValue: 'Import/Export Settings' }) %></h2>
          <p class="muted"><%= t('guildConfig.importExport.subtitle', { defaultValue: "Export this guild's DiscoBot configuration to a file, or import a configuration file from another guild." }) %></p>
        </div>
        <span class="schedule-expander-plus" aria-hidden="true">+</span>
      </summary>
      <div class="settings-expander-body">
        <script id="settingsExportPayload" type="application/json"><%- JSON.stringify(settingsExportPayload || {}) %></script>
        <div class="form-actions">
          <a href="/dashboard/<%= guild.id %>/settings/export" class="btn btn-ghost"><%= t('guildConfig.importExport.exportJson', { defaultValue: 'Export JSON' }) %></a>
          <a href="/dashboard/settings/import-template" class="btn btn-ghost" target="_blank" rel="noopener noreferrer"><%= t('guildConfig.importExport.exampleTemplate', { defaultValue: 'Example Template' }) %></a>
          <button type="button" id="copyJsonBtn" class="btn btn-ghost"><%= t('guildConfig.importExport.copyCurrentJson', { defaultValue: 'Copy Current JSON' }) %></button>
        </div>

        <form method="post" action="/dashboard/<%= guild.id %>/settings/import" class="import-form">
          <label>
            <%= t('guildConfig.importExport.presetJson', { defaultValue: 'Preset JSON' }) %>
            <textarea name="settings_json" id="levelsJsonInput" rows="12" placeholder='{"guild_features":{"moderation":{"enabled":true}},"gamification_levels":[{"level":0,"name":"Newcomer","interactions_required":0}],"moderation_custom_terms":["example term"],"scheduled_messages":[]}' required></textarea>
          </label>
          <p id="jsonValidationMessage" class="muted"></p>
          <div class="form-actions">
            <button type="button" id="validateJsonBtn" class="btn btn-ghost"><%= t('guildConfig.importExport.validateJson', { defaultValue: 'Validate JSON' }) %></button>
            <button type="submit" id="importJsonBtn" class="btn btn-primary" disabled><%= t('guildConfig.importExport.importJson', { defaultValue: 'Import JSON' }) %></button>
          </div>
          <p class="muted helper-text"><%= t('guildConfig.importExport.includeKeysHelp', { defaultValue: 'You can include all settings keys or only specific keys. Only included keys will be updated.' }) %></p>
        </form>
      </div>
    </details>
  </section>
</main>

<script>
  const rowsContainer = document.getElementById('levelRows');
  const addRowBtn = document.getElementById('addRowBtn');
  const copyJsonBtn = document.getElementById('copyJsonBtn');
  const validateJsonBtn = document.getElementById('validateJsonBtn');
  const importJsonBtn = document.getElementById('importJsonBtn');
  const levelsJsonInput = document.getElementById('levelsJsonInput');
  const jsonValidationMessage = document.getElementById('jsonValidationMessage');
  const aiMemberSearchInput = document.getElementById('aiMemberSearchInput');
  const aiMemberSearchResults = document.getElementById('aiMemberSearchResults');
  const aiMemberUserId = document.getElementById('aiMemberUserId');
  const aiMemberUsername = document.getElementById('aiMemberUsername');
  const aiMemberIdDisplay = document.getElementById('aiMemberIdDisplay');

  function validateSettingsPayload(rawText) {
    let parsed;
    try {
      parsed = JSON.parse(String(rawText || '').trim());
    } catch {
      return { ok: false, reason: 'Invalid JSON syntax.' };
    }

    if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
      return { ok: false, reason: 'Settings payload must be a JSON object.' };
    }

    const supportedKeys = ['guild_features', 'gamification_levels', 'moderation_custom_terms', 'scheduled_messages'];
    const includedKeys = supportedKeys.filter((key) => Object.prototype.hasOwnProperty.call(parsed, key));
    if (includedKeys.length === 0) {
      return { ok: false, reason: `Include at least one supported key: ${supportedKeys.join(', ')}.` };
    }

    if (Object.prototype.hasOwnProperty.call(parsed, 'gamification_levels') && !Array.isArray(parsed.gamification_levels)) {
      return { ok: false, reason: 'gamification_levels must be an array if included.' };
    }

    if (Object.prototype.hasOwnProperty.call(parsed, 'moderation_custom_terms') && !Array.isArray(parsed.moderation_custom_terms)) {
      return { ok: false, reason: 'moderation_custom_terms must be an array if included.' };
    }

    if (Object.prototype.hasOwnProperty.call(parsed, 'scheduled_messages') && !Array.isArray(parsed.scheduled_messages)) {
      return { ok: false, reason: 'scheduled_messages must be an array if included.' };
    }

    return { ok: true, includedKeys };
  }

  function wireRemoveButtons() {
    document.querySelectorAll('.remove-row').forEach((btn) => {
      btn.onclick = () => {
        const rows = rowsContainer.querySelectorAll('.level-row');
        if (rows.length <= 1) return;
        btn.closest('.level-row').remove();
      };
    });
  }

  addRowBtn.addEventListener('click', () => {
    const row = document.createElement('div');
    row.className = 'level-row';
    row.innerHTML = `
      <label>Level<input type="number" name="level" min="0" max="100" required /></label>
      <label>Level Name<input type="text" name="level_name" maxlength="24" required /></label>
      <label>XP Required<input type="number" name="interactions_required" min="0" required /></label>
      <button type="button" class="btn btn-ghost remove-row">Remove</button>
    `;
    rowsContainer.appendChild(row);
    wireRemoveButtons();
  });

  copyJsonBtn.addEventListener('click', async () => {
    const payloadNode = document.getElementById('settingsExportPayload');
    const payloadText = payloadNode ? String(payloadNode.textContent || '').trim() : '{}';
    let parsedPayload;
    try {
      parsedPayload = JSON.parse(payloadText);
    } catch {
      parsedPayload = {};
    }

    const json = JSON.stringify(parsedPayload, null, 2);
    levelsJsonInput.value = json;

    try {
      await navigator.clipboard.writeText(json);
      copyJsonBtn.textContent = 'Copied';
      setTimeout(() => {
        copyJsonBtn.textContent = 'Copy Current JSON';
      }, 1400);
    } catch {
      copyJsonBtn.textContent = 'Filled Textarea';
      setTimeout(() => {
        copyJsonBtn.textContent = 'Copy Current JSON';
      }, 1400);
    }
  });

  validateJsonBtn.addEventListener('click', () => {
    const result = validateSettingsPayload(levelsJsonInput.value);
    jsonValidationMessage.classList.remove('validation-success', 'validation-error');

    if (!result.ok) {
      jsonValidationMessage.textContent = `❌ ${result.reason}`;
      jsonValidationMessage.classList.add('validation-error');
      importJsonBtn.disabled = true;
      return;
    }

    jsonValidationMessage.textContent = `✅ Valid settings JSON (${(result.includedKeys || []).join(', ')}).`;
    jsonValidationMessage.classList.add('validation-success');
    importJsonBtn.disabled = false;
  });

  levelsJsonInput.addEventListener('input', () => {
    importJsonBtn.disabled = true;
    jsonValidationMessage.classList.remove('validation-success', 'validation-error');
    jsonValidationMessage.textContent = 'Validation required after any edit.';
  });

  function clearMemberSearchResults() {
    if (!aiMemberSearchResults) {
      return;
    }
    aiMemberSearchResults.innerHTML = '';
    aiMemberSearchResults.hidden = true;
  }

  function selectMemberResult(member) {
    if (!member) {
      return;
    }

    if (aiMemberUserId) {
      aiMemberUserId.value = String(member.user_id || '');
    }
    if (aiMemberUsername) {
      aiMemberUsername.value = String(member.username || '');
    }
    if (aiMemberIdDisplay) {
      aiMemberIdDisplay.value = String(member.user_id || '');
    }
    if (aiMemberSearchInput) {
      aiMemberSearchInput.value = `${String(member.username || member.user_id)} (${String(member.user_id || '')})`;
    }

    clearMemberSearchResults();
  }

  let aiMemberSearchDebounce = null;
  aiMemberSearchInput?.addEventListener('input', () => {
    const q = String(aiMemberSearchInput.value || '').trim();

    if (aiMemberUserId) {
      aiMemberUserId.value = '';
    }
    if (aiMemberUsername) {
      aiMemberUsername.value = '';
    }
    if (aiMemberIdDisplay) {
      aiMemberIdDisplay.value = '';
    }

    if (q.length < 2) {
      clearMemberSearchResults();
      return;
    }

    if (aiMemberSearchDebounce) {
      clearTimeout(aiMemberSearchDebounce);
    }

    aiMemberSearchDebounce = setTimeout(async () => {
      try {
        const response = await fetch(`/dashboard/<%= guild.id %>/members/search?q=${encodeURIComponent(q)}`);
        const payload = await response.json();
        const members = Array.isArray(payload?.members) ? payload.members : [];

        if (!aiMemberSearchResults) {
          return;
        }

        aiMemberSearchResults.innerHTML = '';
        if (members.length === 0) {
          aiMemberSearchResults.hidden = true;
          return;
        }

        members.slice(0, 10).forEach((member) => {
          const row = document.createElement('button');
          row.type = 'button';
          row.className = 'btn btn-ghost';
          row.style.width = '100%';
          row.style.justifyContent = 'flex-start';
          row.style.marginBottom = '4px';
          row.textContent = `${String(member.username || member.user_id)} (${String(member.user_id || '')})`;
          row.addEventListener('click', () => selectMemberResult(member));
          aiMemberSearchResults.appendChild(row);
        });

        aiMemberSearchResults.hidden = false;
      } catch {
        clearMemberSearchResults();
      }
    }, 220);
  });

  document.addEventListener('click', (event) => {
    if (!aiMemberSearchResults || !aiMemberSearchInput) {
      return;
    }

    const target = event.target;
    if (!(target instanceof Element)) {
      return;
    }

    if (target === aiMemberSearchInput || aiMemberSearchResults.contains(target)) {
      return;
    }

    clearMemberSearchResults();
  });

  document.querySelectorAll('.feature-control-card').forEach((card) => {
    const enabledInput = card.querySelector('.feature-enabled-input');
    const cleanupLabel = card.querySelector('.feature-cleanup-label');
    const cleanupInput = cleanupLabel ? cleanupLabel.querySelector('input[type="checkbox"]') : null;

    if (!enabledInput || !cleanupLabel) {
      return;
    }

    const syncCleanupVisibility = () => {
      const isEnabled = enabledInput.checked;
      cleanupLabel.classList.toggle('feature-cleanup-hidden', isEnabled);
      if (isEnabled && cleanupInput) {
        cleanupInput.checked = false;
      }
    };

    enabledInput.addEventListener('change', syncCleanupVisibility);
    syncCleanupVisibility();
  });

  function syncScheduleFormVisibility(form) {
    if (!form) {
      return;
    }

    const recurrenceSelect = form.querySelector('select[name="recurrence"]');
    if (!recurrenceSelect) {
      return;
    }

    const recurrence = String(recurrenceSelect.value || 'once').toLowerCase();
    const onceInput = form.querySelector('.schedule-once-input');
    const startDateInput = form.querySelector('.schedule-start-date');
    const sendTimeInput = form.querySelector('.schedule-send-time');
    const weekdayBoxes = Array.from(form.querySelectorAll('input[name="weekly_days"]'));

    const setGroupVisibility = (selector, isVisible) => {
      const group = form.querySelector(selector);
      if (group) {
        group.hidden = !isVisible;
      }
    };

    const isOnce = recurrence === 'once';
    const isDaily = recurrence === 'daily';
    const isWeekly = recurrence === 'weekly';

    setGroupVisibility('.field-next-run', isOnce);
    setGroupVisibility('.field-start-date', isDaily || isWeekly);
    setGroupVisibility('.field-send-time', isDaily || isWeekly);
    setGroupVisibility('.field-weekdays', isWeekly);
    setGroupVisibility('.field-end-date', isDaily || isWeekly);

    if (onceInput) {
      onceInput.required = isOnce;
    }
    if (startDateInput) {
      startDateInput.required = !isOnce;
    }
    if (sendTimeInput) {
      sendTimeInput.required = isDaily || isWeekly;
    }
    weekdayBoxes.forEach((checkbox) => {
      checkbox.required = false;
    });

    if (isWeekly && weekdayBoxes.length > 0) {
      const anyChecked = weekdayBoxes.some((checkbox) => checkbox.checked);
      weekdayBoxes[0].required = !anyChecked;
    }
  }

  function autoSelectScheduleTimezone(form) {
    if (!form) {
      return;
    }

    const action = String(form.getAttribute('action') || '');
    if (!action.includes('/schedules/create')) {
      return;
    }

    const timezoneSelect = form.querySelector('select[name="timezone_name"]');
    const customTimezoneInput = form.querySelector('input[name="custom_timezone_name"]');
    if (!timezoneSelect) {
      return;
    }

    const currentValue = String(timezoneSelect.value || '').trim();
    const hasCustomTimezone = customTimezoneInput && String(customTimezoneInput.value || '').trim().length > 0;
    if (currentValue && currentValue !== 'UTC') {
      return;
    }
    if (hasCustomTimezone) {
      return;
    }

    const detectedTimeZone = String(Intl.DateTimeFormat().resolvedOptions().timeZone || '').trim();
    if (!detectedTimeZone) {
      return;
    }

    const matchingOption = Array.from(timezoneSelect.options).find((option) => String(option.value || '') === detectedTimeZone);
    if (matchingOption) {
      timezoneSelect.value = detectedTimeZone;
      return;
    }

    if (customTimezoneInput && !String(customTimezoneInput.value || '').trim()) {
      customTimezoneInput.value = detectedTimeZone;
    }
  }

  function wirePickerIconClicks() {
    const pickerInputs = document.querySelectorAll('input[type="date"], input[type="time"], input[type="datetime-local"]');

    pickerInputs.forEach((input) => {
      if (input.closest('.picker-input-wrap')) {
        return;
      }

      input.classList.add('picker-enhanced');

      const wrapper = document.createElement('span');
      wrapper.className = 'picker-input-wrap';

      const trigger = document.createElement('button');
      trigger.type = 'button';
      trigger.className = `picker-trigger picker-trigger-${input.type}`;

      let tooltipText = 'Open Date/Time Picker';
      if (input.type === 'date') {
        tooltipText = 'Open Date Picker';
      } else if (input.type === 'time') {
        tooltipText = 'Open Time Picker';
      }

      trigger.title = tooltipText;
      trigger.setAttribute('aria-label', tooltipText);

      input.parentNode.insertBefore(wrapper, input);
      wrapper.appendChild(input);
      wrapper.appendChild(trigger);

      trigger.addEventListener('click', () => {
        input.focus();
        if (typeof input.showPicker === 'function') {
          try {
            input.showPicker();
            return;
          } catch {}
        }

        input.click();
      });
    });
  }

  function syncScheduleStatusAppearance(form) {
    if (!form) {
      return;
    }

    const statusSelect = form.querySelector('select[name="active"]');
    if (!statusSelect) {
      return;
    }

    const value = String(statusSelect.value || '').trim().toLowerCase();
    statusSelect.classList.remove('status-active', 'status-paused');

    if (value === 'true') {
      statusSelect.classList.add('status-active');
      return;
    }

    statusSelect.classList.add('status-paused');
  }

  function wireCreateScheduleValidationExpander() {
    const createForm = document.querySelector('form[action*="/schedules/create"]');
    if (!createForm) {
      return;
    }

    const createExpander = createForm.closest('details.schedule-create-expander');
    if (!createExpander) {
      return;
    }

    createForm.addEventListener(
      'invalid',
      (event) => {
        const parentSettingsExpander = createExpander.closest('details.settings-expander');
        if (parentSettingsExpander) {
          parentSettingsExpander.open = true;
        }
        createExpander.open = true;
        const target = event.target;
        if (target && typeof target.scrollIntoView === 'function') {
          target.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }
      },
      true
    );
  }

  document.querySelectorAll('form[action*="/schedules/"]').forEach((scheduleForm) => {
    const recurrenceSelect = scheduleForm.querySelector('select[name="recurrence"]');
    const weekdayBoxes = Array.from(scheduleForm.querySelectorAll('input[name="weekly_days"]'));
    const statusSelect = scheduleForm.querySelector('select[name="active"]');

    if (recurrenceSelect) {
      recurrenceSelect.addEventListener('change', () => {
        syncScheduleFormVisibility(scheduleForm);
      });
    }

    weekdayBoxes.forEach((checkbox) => {
      checkbox.addEventListener('change', () => {
        syncScheduleFormVisibility(scheduleForm);
      });
    });

    if (statusSelect) {
      statusSelect.addEventListener('change', () => {
        syncScheduleStatusAppearance(scheduleForm);
      });
    }

    syncScheduleFormVisibility(scheduleForm);
    syncScheduleStatusAppearance(scheduleForm);
    autoSelectScheduleTimezone(scheduleForm);
  });

  wirePickerIconClicks();
  wireCreateScheduleValidationExpander();

  wireRemoveButtons();
</script>

<%- include('partials/foot') %>
